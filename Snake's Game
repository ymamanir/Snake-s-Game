import tkinter as tk
import random

# Configuración del mapa 
ANCHO_CELDAS = 32
ALTO_CELDAS = 20
TAMANO_CELDA = 20  

class JuegoSerpiente:
    def __init__(self, ventana):
        self.ventana = ventana
        self.ventana.title("Juego de la Serpiente")
        
        # Creando ventana para el juego
        self.canvas = tk.Canvas(
            ventana, 
            width=ANCHO_CELDAS * TAMANO_CELDA, 
            height=ALTO_CELDAS * TAMANO_CELDA, 
            bg="black"
        )
        self.canvas.pack()

        # Etiqueta para mostrar el puntaje
        self.etiqueta_puntaje = tk.Label(
            ventana, 
            text="Puntaje: 0", 
            font=("Arial", 14), 
            fg="black"
        )
        self.etiqueta_puntaje.pack()

        
        self.ventana.bind("<Key>", self.cambiar_direccion)

        # Iniciar variables del juego
        self.reiniciar_juego()

    def reiniciar_juego(self):
        
        self.serpiente = [
            [ALTO_CELDAS // 5, ANCHO_CELDAS // 4],
            [ALTO_CELDAS // 5 - 1, ANCHO_CELDAS // 4],
            [ALTO_CELDAS // 5 - 2, ANCHO_CELDAS // 4]
        ]
        self.comida = [3, 2]
        self.puntaje = 0
        self.direccion = [1, 0]  # [dy, dx] -> Avanza hacia abajo al inicio
        self.en_juego = True
        
        self.actualizar_etiqueta()
        self.bucle_principal()

    def cambiar_direccion(self, evento):
        tecla = evento.keysym.lower()
        
        # Controlar los cambios de dirección usando tu misma lógica [y, x]
        if (tecla == 'w' or tecla == 'up') and self.direccion != [1, 0]:
            self.direccion = [-1, 0]
        elif (tecla == 's' or tecla == 'down') and self.direccion != [-1, 0]:
            self.direccion = [1, 0]
        elif (tecla == 'a' or tecla == 'left') and self.direccion != [0, 1]:
            self.direccion = [0, -1]
        elif (tecla == 'd' or tecla == 'right') and self.direccion != [0, -1]:
            self.direccion = [0, 1]

    def dibujar_elemento(self, coordenada, color, tag):
        # Traduce las coordenadas de matriz [y, x] a píxeles en la pantalla
        y, x = coordenada
        x1 = x * TAMANO_CELDA
        y1 = y * TAMANO_CELDA
        x2 = x1 + TAMANO_CELDA
        y2 = y1 + TAMANO_CELDA
        self.canvas.create_rectangle(x1, y1, x2, y2, fill=color, outline="gray20", tags=tag)

    def dibujar_pantalla(self):
        #Limpiar la base
        self.canvas.delete("all")

        # Dibujar los bordes 
        for y in range(ALTO_CELDAS):
            for x in range(ANCHO_CELDAS):
                if y == 0 or y == ALTO_CELDAS - 1 or x == 0 or x == ANCHO_CELDAS - 1:
                    self.dibujar_elemento([y, x], "blue", "pared")

        # Dibujar la comida 
        self.dibujar_elemento(self.comida, "red", "comida")

        # Dibujar la serpiente
        for parte in self.serpiente:
            self.dibujar_elemento(parte, "green", "serpiente")

    def actualizar_etiqueta(self):
        self.etiqueta_puntaje.config(text=f"Puntaje: {self.puntaje}")

    def mostrar_game_over(self, mensaje):
        self.canvas.create_text(
            (ANCHO_CELDAS * TAMANO_CELDA) // 2,
            (ALTO_CELDAS * TAMANO_CELDA) // 2,
            text=f"¡Finalizo!\n{mensaje}\n\nPresiona 'R' si desea continuar",
            fill="white",
            font=("Arial", 16),
            justify="center"
        )
        # Habilitar la tecla R para reiniciar el Juego
        self.ventana.bind("<r>", lambda e: self.reiniciar_juego())

    def bucle_principal(self):
        if not self.en_juego:
            return

        # Movimiento de la cabeza
        nueva_cabeza = [
            self.serpiente[0][0] + self.direccion[0], 
            self.serpiente[0][1] + self.direccion[1]
        ]

        # Colisión con la pared
        if (nueva_cabeza[0] == 0 or nueva_cabeza[0] == ALTO_CELDAS - 1 or 
            nueva_cabeza[1] == 0 or nueva_cabeza[1] == ANCHO_CELDAS - 1):
            self.en_juego = False
            self.dibujar_pantalla()
            self.mostrar_game_over("Chocaste con la pared.")
            return

        # Colisión con el cuerpo
        if nueva_cabeza in self.serpiente:
            self.en_juego = False
            self.dibujar_pantalla()
            self.mostrar_game_over("Golpeaste tu Cuerpo.")
            return

        # Añadir nueva cabeza
        self.serpiente.insert(0, nueva_cabeza)

        # Aparición de comida
        if nueva_cabeza == self.comida:
            self.puntaje += 1
            self.actualizar_etiqueta()
            while True:
                self.comida = [
                    random.randint(1, ALTO_CELDAS - 2), 
                    random.randint(1, ANCHO_CELDAS - 2)
                ]
                if self.comida not in self.serpiente:
                    break
        else:
            self.serpiente.pop()

        # Dibujar todo en el lienzo
        self.dibujar_pantalla()

        # Control del tiempo
        self.ventana.after(200, self.bucle_principal)

# Inicialización de la ventana gráfica
if __name__ == "__main__":
    raiz = tk.Tk()
    juego = JuegoSerpiente(raiz)
    raiz.mainloop()
